# OpenAI / SiliconFlow API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 多模型配置
# 快速分析模型（简单任务：分类、关键词提取）
OPENAI_MODEL_FAST=Qwen/Qwen2.5-7B-Instruct

# 标准分析模型（Multi-Agent 分析）
OPENAI_MODEL_STANDARD=Qwen/Qwen3-VL-32B-Thinking

# 深度分析模型（复杂推理任务）
OPENAI_MODEL_PRO=Qwen/Qwen-Max

# 对话模型（RAG 问答）
OPENAI_MODEL_CHAT=Qwen/Qwen-32B-Chat

# 备用模型（主模型失败时使用）
OPENAI_MODEL_FALLBACK=Qwen/Qwen2.5-14B-Instruct

# 飞书机器人配置
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret_here
# 接收消息的用户 open_id 或 chat_id（群聊）
FEISHU_RECEIVE_ID=oc_xxxxxxxxxxxxxxxx
FEISHU_RECEIVE_ID_TYPE=chat_id

# GitHub Token（可选，用于提高 API 调用限制）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub API 限流配置（每秒请求数）
GITHUB_RATE_LIMIT=10

# 多模态配置（可选）
# README 最大字符数
MULTIMODAL_MAX_CHARS=3000
# 最大图片数量
MULTIMODAL_MAX_IMAGES=3
# 是否启用多模态输入（需要模型支持）
MULTIMODAL_ENABLE=false
