# OpenAI / SiliconFlow API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3-VL-32B-Thinking

# 飞书机器人配置
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret_here
# 接收消息的用户 open_id 或 chat_id（群聊）
FEISHU_RECEIVE_ID=oc_xxxxxxxxxxxxxxxx
FEISHU_RECEIVE_ID_TYPE=chat_id

# GitHub Token（可选，用于提高 API 调用限制）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多模态配置（可选）
# README 最大字符数
MULTIMODAL_MAX_CHARS=3000
# 最大图片数量
MULTIMODAL_MAX_IMAGES=3
# 是否启用多模态输入（需要模型支持）
MULTIMODAL_ENABLE=false