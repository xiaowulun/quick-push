# OpenAI / SiliconFlow
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# Optional 3-tier model override (easy / medium / hard)
# OPENAI_MODEL_EASY=Qwen/Qwen3-32B
# OPENAI_MODEL_MEDIUM=Pro/MiniMaxAI/MiniMax-M2.5
# OPENAI_MODEL_HARD=Pro/deepseek-ai/DeepSeek-V3

# Feishu
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_RECEIVE_ID=oc_xxxxxxxxxxxxxxxx
FEISHU_RECEIVE_ID_TYPE=chat_id

# GitHub (optional but recommended)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Reddit (optional)
REDDIT_COOKIE=

# Rerank model (optional override)
RERANK_MODEL_NAME=BAAI/bge-reranker-base
